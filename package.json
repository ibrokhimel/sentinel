{
  "name": "sentinel",
  "version": "0.1.0",
  "description": "A macOS GUI that keeps your Telegram bots running 24/7 via launchd.",
  "author": "adrianmid98",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "rebuild": "electron-rebuild -f -w @homebridge/node-pty-prebuilt-multiarch",
    "postinstall": "electron-rebuild -f -w @homebridge/node-pty-prebuilt-multiarch || echo 'electron-rebuild skipped (embedded terminal will fall back to Terminal.app)'",
    "package": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "0.13.1",
    "dotenv": "17.4.2"
  },
  "devDependencies": {
    "@electron/rebuild": "4.0.4",
    "@types/node": "22.10.5",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "42.4.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "5.7.3",
    "vite": "7.3.5",
    "vitest": "4.1.9"
  }
}
